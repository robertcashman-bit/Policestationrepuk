# Required for email notifications and magic login codes
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required for self-service portal (session + profile storage via Upstash Redis)
# Auto-set when you add the Upstash integration from your Vercel dashboard
UPSTASH_REDIS_REST_URL=https://your-store.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Site URL (used for canonical URLs, sitemap, etc.)
NEXT_PUBLIC_SITE_URL=https://policestationrepuk.org

# Optional — Google Search Console HTML tag verification (omit to skip meta tag)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_token

# Optional — Supabase for form submissions (not needed for self-service portal)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional — blog hero images from Pexels (otherwise SVG→WebP via npm run blog:heroes)
# PEXELS_API_KEY=your_pexels_key
# Optional — Unsplash (if you extend scripts/blog/fetch-hero-images.mjs)
# UNSPLASH_ACCESS_KEY=your_unsplash_key

# Lemon Squeezy — Featured listing payments
# Get your API key from https://app.lemonsqueezy.com/settings/api (copy the full JWT when shown once)
# For Vercel: add LEMONSQUEEZY_API_KEY in the dashboard, or from repo root run:
#   .\scripts\vercel-add-lemonsqueezy-api-key.ps1 "eyJ...your_jwt..."
# Then redeploy so serverless functions pick it up.
LEMONSQUEEZY_API_KEY=your_api_key
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_signing_secret
# Variant IDs from your Lemon Squeezy products
LEMONSQUEEZY_VARIANT_MONTHLY=variant_id_monthly
LEMONSQUEEZY_VARIANT_3MONTH=variant_id_3month
LEMONSQUEEZY_VARIANT_6MONTH=variant_id_6month
LEMONSQUEEZY_VARIANT_YEARLY=variant_id_yearly
