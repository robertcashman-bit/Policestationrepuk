# Required for email notifications on contact/registration forms
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional - Supabase (Phase 2, not required for initial deployment)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Site URL (used for canonical URLs, sitemap, etc.)
NEXT_PUBLIC_SITE_URL=https://policestationrepuk.org

# Optional — Google Search Console HTML tag verification (omit to skip meta tag)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_token
